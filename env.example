# Clave secreta para firmar los tokens JWT.
# Usa una cadena larga y aleatoria. Para generar una:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=pon-aqui-una-clave-larga-y-secreta

# Cadena de conexión a la base de datos.
# - En desarrollo puedes dejarla VACÍA y se usará SQLite (archivo raices.db).
# - En Supabase / UCR pega aquí la URL de PostgreSQL, por ejemplo:
#   DATABASE_URL=postgresql://usuario:contrasena@host:5432/nombre_db
DATABASE_URL=

# Horas de validez del token (decidimos 24h).
JWT_EXP_HOURS=24
